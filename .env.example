# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT signing secret — use a long random string (min 32 chars)
JWT_SECRET=replace-with-a-long-random-secret

# Admin account seeded into the database
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Port the API server listens on (default: 8080)
PORT=8080

# WhatsApp number for order redirects (country code + number, no + prefix)
# Example for Pakistan: 923001234567
WHATSAPP_NUMBER=923159408619

# Frontend env vars (prefix with VITE_ to expose to the browser build)
VITE_WHATSAPP_NUMBER=923159408619

# Base URL for the API — set to empty string when API is served from same origin via proxy
# For standalone deployments where API is on a different host, set the full URL:
# VITE_API_BASE_URL=https://api.hbf.example.com
VITE_API_BASE_URL=
